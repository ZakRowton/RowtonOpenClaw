# Example nginx config for LOCAL development — proxy to OpenClaw gateway
# Use when you run nginx in front of the gateway locally and see 507.
#
# 1. Copy to a path nginx can read, e.g.:
#      cp nginx-openclaw-local.conf.example /etc/nginx/sites-available/openclaw-local
#      ln -s /etc/nginx/sites-available/openclaw-local /etc/nginx/sites-enabled/
#    Or on Windows (nginx from nginx.org): copy into conf/ and include from nginx.conf.
# 2. Fix the include path below to point to nginx-openclaw-upstream.conf.
# 3. Reload nginx.

events {
    worker_connections 1024;
}

http {
    include       mime.types;
    default_type  application/octet-stream;

    # Upstream to your local OpenClaw gateway (default port 18789)
    upstream openclaw_local {
        server 127.0.0.1:18789;
    }

    server {
        listen 8080;
        server_name localhost;

        location / {
            # Include buffer settings to avoid 507 on retry
            include /path/to/openclaw/claw/.deploy/nginx-openclaw-upstream.conf;

            proxy_pass http://openclaw_local;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_read_timeout 86400s;
            proxy_send_timeout 86400s;
        }
    }
}
